{
  "name": "Webex Player Addons",
  "description": "Enhancer for Webex ",
  "homepage_url": "https://github.com/giorgiolongo/webexplayeraddons",
  "version": "2.5",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "webexplayeraddons@giorgiolongo",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "webRequest"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "run_at" : "document_end",
      "js": [
        "src/utils.js",
        "src/downloadenabler.js",
        "src/spacebar.js",
        "src/sidebar.js",
        "src/speedslider.js",
        "src/volumeslider.js",
        "src/silenceskip.js",
        "src/zoomslider.js",
        "src/hideuibuttons.js",
        "src/persistmedia.js",
        "src/endtime.js",
        "src/optionsmenu.js"
      ],
      "matches": [
        "*://*.webex.com/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "host_permissions": [
    "*://*.webex.com/*",
    "https://api.github.com/repos/giorgiolongo/webexplayeraddons/releases/latest"
  ]
}
